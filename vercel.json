{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/login",          "destination": "/index.html" },
    { "source": "/accounts",       "destination": "/index.html" },
    { "source": "/accounts/:id",      "destination": "/index.html" },
    { "source": "/accounts/:id/edit", "destination": "/index.html" },
    { "source": "/renewal",        "destination": "/index.html" },
    { "source": "/rag",            "destination": "/index.html" },
    { "source": "/escalations",         "destination": "/index.html" },
    { "source": "/escalations/weekly", "destination": "/index.html" },
    { "source": "/issues",             "destination": "/index.html" },
    { "source": "/settings",           "destination": "/index.html" },
    { "source": "/",               "destination": "/index.html" }
  ]
}
